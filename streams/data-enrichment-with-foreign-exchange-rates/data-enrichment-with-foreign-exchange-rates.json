      "nodeIds": ["e1df0760-51b2-11ea-bec0-a7e1071491c2"],
      "annotation": {
        "text": "Saves the result to a log file.\nThe data can be used for billing, reconciliation, or settlement purposes by replacing the log with a forwarder function.",
        "color": "gray"
      }
    },
    {
      "id": "8a2e2720-3641-11f0-af1e-f1cd79e81557",
      "name": "Generate sample usage data",
      "nodeIds": [
        "5198efa0-51b1-11ea-bec0-a7e1071491c2",
        "59fe4a00-51b1-11ea-bec0-a7e1071491c2"
      ],
      "annotation": {
        "text": "Generates records representing transactions in various currencies, each of which has a service fee.",
        "color": "gray"
      }
    },
    {
      "id": "b7142410-3641-11f0-af1e-f1cd79e81557",
      "name": "Get exchange rates",
      "nodeIds": ["cff347b0-51b1-11ea-bec0-a7e1071491c2"],
      "annotation": {
        "text": "Looks up the exchange rates, in this case, from a DR-hosted API",
        "color": "green"
      }
    },
    {
      "id": "c704f390-3641-11f0-af1e-f1cd79e81557",
      "name": "Convert fees to USD",
      "nodeIds": ["6b1f6590-ba28-11eb-8ba4-7393f6d56d99"],
      "annotation": {
        "text": "Converts the service fee amount to USD from the lookup data.",
        "color": "yellow"
      }
    }
  ]
