{
  "name": "Data Enrichment With Foreign Exchange Rates",
  "annotation": {
    "text": "This example stream demonstrates how the fictional consulting firm Globetrek enriches transaction data with foreign exchange rates, converting client service fees from various currencies into US Dollars.\n\nEach record is looked up against a currency API to retrieve the current rate, and the service fee is then recalculated in USD for use in downstream billing or reconciliation.\n\nThe example uses a DR-hosted API for the exchange-rate lookup; you can easily swap it for any external API of your choice.",
    "color": "blue"
  },
  "nodes": [
    {
      "id": "5198efa0-51b1-11ea-bec0-a7e1071491c2",
      "type": "readers/counter",
      "schemaVersion": 2,
      "name": "Count",
      "params": {
        "max": 1
      },
      "x": 350,
      "y": 200
    },
    {
      "id": "59fe4a00-51b1-11ea-bec0-a7e1071491c2",
      "type": "transforms/script",
      "schemaVersion": 1,
      "name": "Simulate Data",
      "params": {
        "transform": "// Simulate sample data\n\nconst event = [\n    {\n        \"Name\": \"User-0\",\n        \"ServiceFee\": 25,\n        \"Currency\": \"SEK\"   \n    },\n    {\n        \"Name\": \"User-1\",\n        \"ServiceFee\": 10,\n        \"Currency\": \"EUR\"   \n    },\n    {\n        \"Name\": \"User-2\",\n        \"ServiceFee\": 4,\n        \"Currency\": \"GBP\"   \n    },\n    {\n        \"Name\": \"User-3\",\n        \"ServiceFee\": 7,\n        \"Currency\": \"AUD\"   \n    }\n]\n\n\nfor (var key in event) {\n    await push(event[key]);\n}"
      },
      "x": 650,
      "y": 200
    },
    {
      "id": "6b1f6590-ba28-11eb-8ba4-7393f6d56d99",
      "type": "transforms/xmap",
      "schemaVersion": 3,
      "name": "Convert Fees",
      "params": {
        "keepFields": {
          "enabled": true,
          "except": [
            "httpResponse"
          ]
        },
        "mappings": [
          {
            "ast": [
              "IP",
              "${payload.httpResponse.rates.USD}"
            ],
            "errorMessage": null,
            "expression": "httpResponse.rates.USD",
            "field": "USD Exchange Rate"
          },
          {
            "ast": [
              "aop",
              "/",
              [
                "call",
                [
                  "R",
                  "round"
                ],
                [
                  [
                    "aop",
                    "*",
                    [
                      "aop",
                      "*",
                      [
                        "IP",
                        "${payload.ServiceFee}"
                      ],
                      [
                        "IP",
                        "${payload.httpResponse.rates.USD}"
                      ]
                    ],
                    [
                      "N",
                      10000
                    ]
                  ]
                ]
              ],
              [
                "N",
                10000
              ]
            ],
            "errorMessage": null,
            "expression": "round(ServiceFee * httpResponse.rates.USD * 10000) / 10000",
            "field": "Service Fee (USD)"
          }
        ]
      },
      "x": 1200,
      "y": 200
    },
    {
      "id": "cff347b0-51b1-11ea-bec0-a7e1071491c2",
      "type": "transforms/http",
      "schemaVersion": 15,
      "name": "Exchange Rate",
      "params": {
        "authType": "basic",
        "basicAuthentication": {
          "password": {
            "encryptedValue": "kms:AQICAHgmkWEN+gbMC4v32WaRttX6Ss3X3c62n8OQ92yRFRwWaAHytrKDDcdHmaJqujbYAcfRAAAAYjBgBgkqhkiG9w0BBwagUzBRAgEAMEwGCSqGSIb3DQEHATAeBglghkgBZQMEAS4wEQQMZjE6lFjw7ACt8M0gAgEQgB80M5aY2rxxhOgJWsa6D3toI3nnfz7z3o+v6wZH6rzr",
            "maskedValue": "****",
            "secret": true
          },
          "username": "test"
        },
        "cacheKey": "${payload.Base_Currency}",
        "cacheSeconds": 300,
        "enableParallelProcessing": false,
        "errorMode": "emit",
        "maxConcurrentRequests": 20,
        "method": "GET",
        "qs": [
          {
            "key": "base",
            "value": "${payload.Currency}"
          },
          {
            "key": "symbols",
            "value": "USD"
          }
        ],
        "retries": 1,
        "shouldRetry": false,
        "uri": "https://ingress.digitalroute.io/53d1b880-a9b5-11eb-903c-7f5f6b522c3e/rates",
        "useCache": false
      },
      "x": 900,
      "y": 200
    },
    {
      "id": "e1df0760-51b2-11ea-bec0-a7e1071491c2",
      "type": "writers/log",
      "schemaVersion": 1,
      "name": "Log",
      "params": {},
      "x": 1500,
      "y": 200
    }
  ],
