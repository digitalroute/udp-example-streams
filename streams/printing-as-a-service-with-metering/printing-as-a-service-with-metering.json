      "name": "Format deactivate",
      "params": {
        "transform": "const threshold = payload.thresholds.find(threshold => threshold?.customFields?.action === \"DEACTIVATE_PRINTER\");\n\nawait push({\n    ...payload,\n    message: \"The printer with id \" + payload.userId + \" has reached the maximum prints and must be deactivated. Prints taken: \" + threshold?.absoluteValue\n});"
