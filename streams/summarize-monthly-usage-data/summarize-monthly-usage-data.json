{
  "name": "Summarize Monthly Usage Data",
  "annotation": {
    "text": "This example stream demonstrates how the fictional gaming platform Punk Games bills its users monthly based on the number of games they download.\n\nEach user's daily game-download counts are aggregated into a per-user monthly total, which is sent downstream to a simulated billing system.",
    "color": "blue"
  },
  "nodes": [
    {
      "id": "df2d3300-4cbe-11ea-9014-2b24e4165af9",
      "type": "readers/counter",
      "schemaVersion": 2,
      "name": "Count",
      "params": {
        "max": 5
      },
      "x": 400,
      "y": 200
    },
    {
      "id": "31a45de0-80ba-11eb-b363-0dcbd0a358e8",
      "type": "transforms/data_aggregate",
      "schemaVersion": 3,
      "name": "Data Aggregator",
      "params": {
        "flushType": "ALL_FILES",
        "groupKeys": [
          {
            "field": "userId",
            "operationType": "NONE"
          },
          {
            "field": "dateTime",
            "operationType": "MONTH"
          }
        ],
        "operations": [
          {
            "field": "downloadedGame",
            "type": "NUMERIC_SUM"
          }
        ]
      },
      "x": 800,
      "y": 200
    },
    {
      "id": "5bef9e60-5ec5-11ea-8ba5-d5bb374ad591",
      "type": "transforms/map",
      "schemaVersion": 2,
      "name": "Monthly Record",
      "params": {
        "mappings": [
          {
            "Month": "month_dateTime"
          },
          {
            "TotalDownload": "sum_downloadedGame"
          },
          {
            "User": "userId"
          }
        ]
      },
      "x": 1050,
      "y": 200
    },
    {
      "id": "ec556ca0-4cbe-11ea-9014-2b24e4165af9",
      "type": "transforms/script",
      "schemaVersion": 1,
      "name": "Simulate Data",
      "params": {
        "transform": "// This script simulate daily record for number of games downloaded by a user\n\n// Write the input record from previous function into log\nlog.info (\"Receive data: \" + JSON.stringify(payload));\n\n// Create sample daily record\nvar usageEvent = {\n    eventId: payload.value,\n    userId: \"USER-1001\",\n    downloadedGame: 2 * payload.value,\n    dateTime: simDate(),\n}\n\n// Send the record to next function\nawait push(usageEvent)\n\n// Simulate different date for each record\nfunction simDate() {\n    var moment = require(\"moment\");\n    var date = moment().add(payload.value, 'days');\n    return date.format('YYYY-MM-DD');\n}"
      },
      "x": 550,
      "y": 200
    },
    {
      "id": "84b4dea0-51c3-11ea-bec0-a7e1071491c2",
      "type": "writers/log",
      "schemaVersion": 1,
      "name": "Log",
      "params": {},
      "x": 1200,
      "y": 200
    }
  ],
  "edges": [
